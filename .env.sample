# -----------------------------------
# Server
# -----------------------------------
NODE_ENV=development
PORT=4000
API_PREFIX=/api

# -----------------------------------
# Database (PostgreSQL)
# -----------------------------------
DATABASE_URL=postgresql://triage:triagepass@localhost:5432/triage_db?schema=public

# -----------------------------------
# Redis (used by Bull queues)
# -----------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# -----------------------------------
# CORS
# -----------------------------------
CORS_ORIGIN=http://localhost:3000

# -----------------------------------
# Rate Limiting
# -----------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# -----------------------------------
# OpenAI
# -----------------------------------
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_MS=30000

# -----------------------------------
# Logging
# -----------------------------------
LOG_LEVEL=info
